{
  "name": "@cyfrin/battlechain-lib",
  "description": "Foundry library for deploying on BattleChain and adopting Safe Harbor agreements",
  "version": "1.1.1",
  "type": "module",
  "exports": {
    "./src/*": "./src/*",
    "./deployments.json": "./deployments.json",
    "./abis/*": "./abis/*"
  },
  "files": [
    "/src/**/*.sol",
    "!/src/**/mocks/**/*",
    "/deployments.json",
    "/abis/**/*.json",
    "/LICENCE-MIT",
    "/LICENCE-APACHE"
  ],
  "scripts": {
    "build": "forge build",
    "codegen": "forge build && node scripts/codegen.mjs",
    "test": "forge test",
    "lint": "forge fmt --check",
    "lint:fix": "forge fmt",
    "publish:npm": "npm publish --access public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cyfrin/battlechain-lib"
  },
  "keywords": [
    "solidity",
    "foundry",
    "battlechain",
    "safe-harbor",
    "smart-contracts",
    "zksync",
    "deployment"
  ],
  "author": "Cyfrin <security@cyfrin.io>",
  "license": "MIT OR Apache-2.0",
  "bugs": {
    "url": "https://github.com/Cyfrin/battlechain-lib/issues"
  },
  "homepage": "https://docs.battlechain.com"
}